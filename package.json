{
  "name": "kinkane-server",
  "version": "1.0.0",
  "description": "Kinkane main API server",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:init": "tsx src/db/install-extensions.ts && npm run db:migrate && tsx src/db/setup.ts",
    "db:reset": "tsx src/db/reset.ts"
  },
  "dependencies": {
    "@bull-board/api": "^7.1.5",
    "@bull-board/express": "^7.1.5",
    "@google/generative-ai": "^0.24.1",
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.77.6",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.10.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "postgres": "^3.4.4",
    "rate-limit-redis": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.27.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
